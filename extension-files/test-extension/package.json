{
  "name": "bringweb3-mock-extension",
  "version": "0.1.0",
  "description": "Mock extension for the bringweb3-sdk",
  "private": true,
  "scripts": {
    "watch": "node --env-file=.env ./node_modules/webpack/bin/webpack.js --mode=development --watch --config config/webpack.config.js",
    "build": "node --env-file=.env ./node_modules/webpack/bin/webpack.js --mode=production --config config/webpack.config.js",
    "build:prod": "BUILD_ENV= node --env-file=.env ./node_modules/webpack/bin/webpack.js --mode=production --config config/webpack.config.js",
    "build:env": "node --env-file=.env ./node_modules/webpack/bin/webpack.js --mode=production --config config/webpack.config.js"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.11.0",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "webpack": "^5.104.1",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0"
  },
  "dependencies": {},
  "resolutions": {
    "tar": "^7.5.11",
    "serialize-javascript": "^7.0.5",
    "lodash": "^4.18.0",
    "axios": "^0.31.0",
    "webpack": "^5.104.1",
    "minimatch": "^9.0.7",
    "picomatch": "^2.3.2",
    "micromatch": "^4.0.8",
    "cross-spawn": "^7.0.5",
    "brace-expansion": "^2.0.3",
    "nanoid": "^3.3.8",
    "postcss": "^8.5.10",
    "ajv": "^8.17.1",
    "follow-redirects": "^1.16.0"
  }
}